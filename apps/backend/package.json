    "express": "^4.19.2",
    "groq-sdk": "^0.7.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.5",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",

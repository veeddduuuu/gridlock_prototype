# ── Backend (apps/backend/.env) ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-rest-of-url.neon.tech/neondb?sslmode=require"
JWT_SECRET="examplejwtsecret"
GROQ_API_KEY="your-groq-api-key"
GROQ_MODEL_ID="openai/gpt-oss-120b"
MAPPLS_API_KEY="the-api-key"
MAPMYINDIA_API="copy-the-same-above-api-key"
# Where the backend reaches the ML service and Redis (defaults shown):
ML_SERVICE_URL="http://localhost:8000"
REDIS_URL="redis://127.0.0.1:6379"

